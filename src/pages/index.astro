	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			const section = document.getElementById('testimonials-section');
			const row1 = document.getElementById('scroll-row-1');
			const row2 = document.getElementById('scroll-row-2');

			function updateScroll() {
				if (!section || !row1 || !row2) return;
				const rect = section.getBoundingClientRect();
				const offset = window.innerHeight - rect.top;
				if (offset > 0 && rect.bottom > 0) {
					row1.style.transform = `translateX(calc(-15% + ${offset * 0.2}px))`;
					row2.style.transform = `translateX(calc(5% - ${offset * 0.2}px))`;
				}
			}
			window.addEventListener('scroll', updateScroll);
			updateScroll();

			// Case Studies Carousel Logic
			function updateCarousel() {
				const carousel = document.getElementById('case-studies-carousel');
				if (!carousel) return;
				const containerRect = carousel.getBoundingClientRect();
				const containerCenter = containerRect.left + containerRect.width / 2;
				const cards = carousel.querySelectorAll('.carousel-card');
				let closestCard = null;
				let minDistance = Infinity;

				cards.forEach(card => {
					const cardRect = card.getBoundingClientRect();
					const cardCenter = cardRect.left + cardRect.width / 2;
					const distance = Math.abs(containerCenter - cardCenter);
					if (distance < minDistance) {
						minDistance = distance;
						closestCard = card;
					}
				});

				cards.forEach(card => {
					if (card === closestCard) {
						card.classList.add('scale-100', 'opacity-100');
						card.classList.remove('scale-95', 'opacity-80');
					} else {
						card.classList.remove('scale-100', 'opacity-100');
						card.classList.add('scale-95', 'opacity-80');
					}
				});
			}

			const csCarousel = document.getElementById('case-studies-carousel');
			if (csCarousel) {
				csCarousel.addEventListener('scroll', updateCarousel);
				window.addEventListener('resize', updateCarousel);
				setTimeout(updateCarousel, 50); // Initial check
			}
		});
	</script>
