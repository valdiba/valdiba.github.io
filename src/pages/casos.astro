---
import Layout from "../layouts/Layout.astro";
import CaseStudyModal from "../components/CaseStudyModal.astro";
import { caseStudiesData, coverMap, coverClasses, floatingCards } from "../data/caseStudies.ts";
---

<Layout class="bg-white">
  {caseStudiesData.map((caseData) => (
    <CaseStudyModal {...caseData as any} />
  ))}

  <!-- ========================================== -->
  <!-- NUEVO LAYOUT EXPERIMENTAL (FLOTANTE)       -->
  <!-- ========================================== -->
  <section
    class="relative w-full flex flex-col items-center justify-start overflow-hidden pt-24 pb-32 bg-white"
  >
    <!-- Título Central -->
    <div class="relative z-20 max-w-3xl lg:max-w-4xl text-center px-6 mb-16">
      <img
        src="/pc.png"
        alt="PC decoration"
        class="w-16 md:w-24 lg:w-32 mx-auto mb-6 object-contain"
      />
      <span
        class="font-bold tracking-wider uppercase text-brand text-sm mb-4 block"
        >Case studies</span
      >
      <h2
        class="text-4xl md:text-5xl lg:text-7xl tracking-[-0.07em] text-balance text-gray-950"
      >
        Turning Complex Challenges into Seamless Experiences
      </h2>
      <p class="mt-6 text-base md:text-lg text-slate-900 font-regular">
        Explore some of my featured case studies.
      </p>
    </div>

    <!-- Contenedor de Cards (Una Fila) -->
    <div
      class="relative z-10 flex flex-wrap justify-center items-start gap-4 sm:gap-8 lg:gap-10 w-full max-w-7xl px-6"
    >
      {
        floatingCards.map((card) => (
          <div
            class="w-24 md:w-32 lg:w-40 p-2 flex flex-col items-center text-center transform hover:-translate-y-2 hover:z-30 transition-all duration-300 cursor-pointer group/float"
            onclick={`document.getElementById('${card.id}').showModal()`}
          >
            <div class="relative w-full mb-2 md:mb-3">
              <img
                src="/Folder.png"
                alt="Decoración fondo"
                class="w-full h-auto object-contain relative z-0"
              />
              {coverMap[card.id] &&
                coverMap[card.id].map((src, i) => (
                  <img
                    src={src}
                    alt={`${card.id} cover ${i + 1}`}
                    class={coverClasses[i]}
                  />
                ))}
              <img
                src="/Folder2.png"
                alt="Decoración frente"
                class="absolute inset-0 w-full h-full object-contain z-10 transition-transform duration-300 group-hover/float:scale-105"
              />
            </div>
            <h3 class="font-sans tracking-normal font-bold text-slate-900 text-xs md:text-sm leading-tight transition-colors">
              {card.title}
            </h3>
            <p class="text-[9px] md:text-[10px] text-slate-500 font-medium mt-2 uppercase tracking-wider">
              {card.category}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const params = new URLSearchParams(window.location.search);
      const caseId = params.get("case");
      if (caseId) {
        const modal = document.getElementById(`modal-${caseId}`);
        if (modal) {
          modal.showModal();
        }
      }
    });
  </script>
</Layout>
