---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="bg-slate-50 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      
      <!-- Botón de regreso -->
      <div class="mb-12">
        <a href="/casos" class="inline-flex items-center text-sm font-semibold text-slate-500 hover:text-brand transition-colors">
          <span aria-hidden="true" class="mr-2">&larr;</span> Back to Case Studies
        </a>
      </div>

      <!-- Cabecera del Caso -->
      <div class="mx-auto max-w-3xl">
        <div class="flex items-center gap-x-4 text-xs mb-6">
          <span class="text-slate-500">2024-2025</span>
          <span class="rounded-full bg-white px-3 py-1.5 font-medium text-brand ring-1 ring-slate-200 uppercase tracking-wider text-[10px]">Travel & AI</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950 sm:text-6xl mb-6 text-balance">Scaling Growth through Motion & Systems</h1>
        <p class="text-xl leading-8 text-slate-600">Leading cross-platform experiences for web and mobile. Contributed to $14.9M GP and 1.48M installs by surpassing annual targets by 148%.</p>
      </div>

      <!-- Metadatos (Rol, Empresa, etc) -->
      <div class="mx-auto max-w-3xl mt-12 grid grid-cols-2 gap-8 border-y border-slate-200 py-8 sm:grid-cols-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Client</p>
          <p class="mt-2 font-semibold text-slate-900">Expedia Group</p>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-500">Role</p>
          <p class="mt-2 font-semibold text-slate-900">Product Designer</p>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-500">Timeline</p>
          <p class="mt-2 font-semibold text-slate-900">12 Months</p>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-500">Platform</p>
          <p class="mt-2 font-semibold text-slate-900">iOS, Android, Web</p>
        </div>
      </div>

      <!-- Imagen Hero -->
      <div class="mt-16 overflow-hidden rounded-[2rem] shadow-sm ring-1 ring-slate-900/10">
        <img src="/DestinationDecoderExp.svg" alt="Project Hero" class="w-full h-[400px] sm:h-[600px] object-cover bg-white" />
      </div>

      <!-- Contenido del Caso de Estudio -->
      <div class="mx-auto max-w-3xl mt-20 prose prose-lg prose-slate text-slate-700">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">The Challenge</h2>
        <p>Write about the initial problem, the context of the project, and what you set out to solve. This is where you explain the "Why" behind the work. What were the business goals and the user pain points?</p>
        
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 mt-16">The Approach</h2>
        <p>Detail your process, research, user interviews, wireframing, and how you arrived at your proposed solution. You can embed images easily here to show your work in progress.</p>
        
        <figure class="my-10">
          <img src="/DestinationDecoderExp.svg" alt="Wireframes or Process" class="w-full rounded-2xl bg-white shadow-sm ring-1 ring-slate-900/10" />
          <figcaption class="text-center text-sm text-slate-500 mt-4">Description of the interface, process, or component library shown above.</figcaption>
        </figure>

        <h2 class="text-3xl font-bold tracking-tight text-slate-900 mt-16">The Solution</h2>
        <p>Showcase the final designs, the UI components, motion design elements, and how the system scaled. Highlight specific features that drove success and how you collaborated with engineering to make it a reality.</p>

        <h2 class="text-3xl font-bold tracking-tight text-slate-900 mt-16">The Impact</h2>
        <p>Conclude with measurable results, business metrics, and key takeaways.</p>
        <ul class="font-medium text-slate-800">
          <li>Generated $14.9M in Gross Profit.</li>
          <li>Drove 1.48M new app installs.</li>
          <li>Surpassed annual growth targets by 148%.</li>
        </ul>
      </div>
      
      <!-- Siguiente Proyecto -->
      <div class="mx-auto max-w-3xl mt-24 border-t border-slate-200 pt-10 text-center">
        <p class="text-sm font-bold tracking-widest uppercase text-slate-400 mb-4">Up Next</p>
        <a href="#" class="text-2xl font-bold text-slate-900 hover:text-brand transition-colors">Elevating Design Excellence & Ops &rarr;</a>
      </div>

    </div>
  </div>
</Layout>